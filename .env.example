# =============================================================================
# Loyallia — Environment Variables Example
# Copy this to .env and fill in real values
# NEVER commit .env to version control
# =============================================================================

# --- Vault (Secret Management) ---
# In production, use a sealed Vault instance with a proper token
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=loyallia-vault-root-token
VAULT_SECRET_PATH=secret/data/loyallia

# --- Django Core ---
DJANGO_SETTINGS_MODULE=loyallia.settings.production
SECRET_KEY=change-me-generate-with-python-secrets-token-hex-50
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,loyallia.com,www.loyallia.com
CORS_ALLOWED_ORIGINS=http://localhost:33906,https://loyallia.com

# --- Database ---
POSTGRES_DB=loyallia
POSTGRES_USER=loyallia
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- MinIO (S3-Compatible Storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET_PASSES=passes
MINIO_BUCKET_ASSETS=assets
MINIO_USE_SSL=False

# --- Apple Wallet (PassKit) ---
# Obtain from Apple Developer Portal > Certificates > Pass Type IDs
APPLE_PASS_TYPE_IDENTIFIER=pass.com.loyallia.cards
APPLE_TEAM_IDENTIFIER=YOUR_APPLE_TEAM_ID_HERE
APPLE_CERT_PATH=/app/certs/apple_pass.pem
APPLE_CERT_KEY_PATH=/app/certs/apple_pass.key
APPLE_WWDR_CERT_PATH=/app/certs/apple_wwdr.pem
# Generate HMAC signing key: python -c "import secrets; print(secrets.token_hex(32))"
PASS_HMAC_SECRET=generate-a-random-32-byte-hex-string-here
# APNs token-based auth
APPLE_APNS_KEY_ID=YOUR_APNS_KEY_ID
APPLE_APNS_AUTH_KEY_PATH=/app/certs/apns_auth_key.p8

# --- Google Wallet ---
# Obtain from Google Cloud Console > Wallet API
GOOGLE_SERVICE_ACCOUNT_FILE=/app/certs/google_wallet_service_account.json
GOOGLE_WALLET_ISSUER_ID=YOUR_GOOGLE_ISSUER_ID_HERE

# --- Google OAuth 2.0 (Social Login) ---
# Obtain from Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
# Instructions: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:33905/api/v1/auth/google/callback/

# --- Firebase (Android Push Notifications) ---
FIREBASE_CREDENTIAL_FILE=/app/certs/firebase_service_account.json

# --- Payment Gateway (Bendo / PlacetoPay) ---
# Provider: "bendo", "placetopay", or "manual"
PAYMENT_GATEWAY_PROVIDER=bendo
PAYMENT_GATEWAY_BASE_URL=https://checkout.placetopay.com
PAYMENT_GATEWAY_LOGIN=your_placetopay_login
PAYMENT_GATEWAY_TRAN_KEY=your_placetopay_tran_key
PAYMENT_GATEWAY_WEBHOOK_SECRET=your_webhook_secret

# --- Email (SMTP) ---
EMAIL_HOST=smtp.mailjet.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_smtp_username
EMAIL_HOST_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@loyallia.com

# --- App URLs ---
APP_URL=http://localhost
FRONTEND_URL=http://localhost:33906
NEXT_PUBLIC_API_URL=http://localhost:33905
NEXT_PUBLIC_APP_URL=http://localhost:33906

# --- Flower (Celery Monitor) ---
FLOWER_BASIC_AUTH=admin:change_this_flower_password

# --- Business Rules (fallback defaults — real limits in SubscriptionPlan DB) ---
TAX_RATE_ECUADOR=0.15
TRIAL_DAYS=5
GEO_PUSH_COOLDOWN_HOURS=4
GEO_FENCE_RADIUS_METERS=100

# --- Import Limits ---
MAX_IMPORT_FILE_SIZE=10485760
MAX_IMPORT_ROWS=50000
