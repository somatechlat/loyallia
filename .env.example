# =============================================================================
# Loyallia — Environment Variables Example
# Copy this to .env and fill in real values
# NEVER commit .env to version control
# =============================================================================

# --- Django Core ---
DJANGO_SETTINGS_MODULE=loyallia.settings.production
SECRET_KEY=change-me-generate-with-python-secrets-token-hex-50
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,loyallia.com,www.loyallia.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://loyallia.com

# --- Database ---
DATABASE_URL=postgres://loyallia:loyallia_secret@pgbouncer:6432/loyallia
# Direct Postgres URL (for migrations only - bypass pgbouncer)
DATABASE_DIRECT_URL=postgres://loyallia:loyallia_secret@postgres:5432/loyallia
POSTGRES_DB=loyallia
POSTGRES_USER=loyallia
POSTGRES_PASSWORD=loyallia_secret

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- MinIO (S3-Compatible Storage) ---
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=loyallia_minio
MINIO_SECRET_KEY=loyallia_minio_secret
MINIO_BUCKET_PASSES=passes
MINIO_BUCKET_ASSETS=assets
MINIO_USE_SSL=False
# For production with real S3:
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_STORAGE_BUCKET_NAME=loyallia-assets
# AWS_S3_REGION_NAME=us-east-1

# --- Apple Wallet (PassKit) ---
# Obtain from Apple Developer Portal → Certificates → Pass Type IDs
APPLE_PASS_TYPE_IDENTIFIER=pass.com.loyallia.cards
APPLE_TEAM_IDENTIFIER=YOUR_APPLE_TEAM_ID_HERE
APPLE_CERT_PATH=/app/certs/apple_pass.pem
APPLE_CERT_KEY_PATH=/app/certs/apple_pass.key
APPLE_WWDR_CERT_PATH=/app/certs/apple_wwdr.pem
# Generate HMAC signing key for QR tokens
PASS_HMAC_SECRET=generate-a-random-32-byte-hex-string-here

# --- Google Wallet ---
# Obtain from Google Cloud Console → Wallet API
GOOGLE_SERVICE_ACCOUNT_FILE=/app/certs/google_wallet_service_account.json
GOOGLE_WALLET_ISSUER_ID=YOUR_GOOGLE_ISSUER_ID_HERE

# --- Firebase (Android Push Notifications) ---
FIREBASE_CREDENTIAL_FILE=/app/certs/firebase_service_account.json

# --- Claro Pay (Billing) ---
CLARO_PAY_BASE_URL=https://api-uat.claropay.com.ec
CLARO_PAY_MERCHANT_ID=your_claro_pay_merchant_id
CLARO_PAY_API_KEY=your_claro_pay_api_key
CLARO_PAY_API_SECRET=your_claro_pay_api_secret
CLARO_PAY_WEBHOOK_SECRET=your_claro_pay_webhook_secret

# --- Email (SMTP) ---
EMAIL_HOST=smtp.mailjet.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_smtp_username
EMAIL_HOST_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@loyallia.com
EMAIL_REPLY_TO=soporte@loyallia.com

# --- App URLs ---
APP_URL=http://localhost
API_URL=http://localhost/api/v1
NEXT_PUBLIC_API_URL=http://api:8000
NEXT_PUBLIC_APP_URL=http://localhost

# --- Flower (Celery Monitor) ---
FLOWER_BASIC_AUTH=admin:change_this_flower_password

# --- Subscription Pricing ---
PLAN_FULL_PRICE_USD=75.00
PLAN_CURRENCY=USD
TAX_RATE_ECUADOR=0.12

# --- Feature Flags ---
TRIAL_DAYS=14
MAX_PROGRAMS_PER_TENANT=10
MAX_LOCATIONS_PER_TENANT=50
GEO_PUSH_COOLDOWN_HOURS=4
GEO_FENCE_RADIUS_METERS=100
